<section class="section">
  <div class="wrap">
    <div class="form-shell login-shell">
      <h1 class="section-title" style="text-align:center;">Staff Login</h1>
      <% if (errors && errors.general) { %><div class="alert alert-error"><%= errors.general.msg %></div><% } %>
      <form method="POST" action="/admin/login" novalidate>
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <input type="hidden" name="next" value="<%= next %>">
        <div class="field">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" required autocomplete="username">
        </div>
        <div class="field">
          <label for="password">Password</label>
          <input type="password" id="password" name="password" required autocomplete="current-password">
        </div>
        <button class="btn btn-primary" type="submit" style="width:100%;">Log In</button>
      </form>
    </div>
  </div>
</section>
