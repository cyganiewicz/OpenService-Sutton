<section class="section">
  <div class="wrap">
    <h1 class="section-title">Employment Application</h1>
    <p class="section-sub">Town of Sutton — apply for a full-time, part-time, or seasonal position. Fields marked * are required.</p>

    <div class="form-shell">
      <% if (errors && errors.general) { %><div class="alert alert-error"><%= errors.general.msg %></div><% } %>
      <% if (errors && errors.resume) { %><div class="alert alert-error"><%= errors.resume.msg %></div><% } %>
      <div class="alert alert-info">Applicants are considered for all positions without regard to race, color, religion, gender orientation, national origin, age, marital or veteran status, or the presence of a non-job-related medical condition or handicap.</div>

      <form method="POST" action="/employment-application" enctype="multipart/form-data" novalidate>
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="honeypot-field" aria-hidden="true">
          <label for="company_website">Leave this field blank</label>
          <input type="text" id="company_website" name="company_website" tabindex="-1" autocomplete="off">
        </div>

        <% if (vacancies.length) { %>
        <div class="field">
          <label for="vacancyId">Position applying for</label>
          <select id="vacancyId" name="vacancyId">
            <option value="">— General application (no specific posting) —</option>
            <% vacancies.forEach(function(v) { %>
              <option value="<%= v.id %>" <%= vacancyId === v.id ? 'selected' : '' %>><%= v.title %> (<%= v.departmentOrBoard %>)</option>
            <% }); %>
          </select>
        </div>
        <% } %>

        <% fields.forEach(function (field) { %>
          <%- include('partials/dynamic-field', { field: field, value: values[field.name], error: errors[field.name] }) %>
        <% }); %>

        <div class="form-section-title">Employment History</div>
        <% for (let i = 0; i < 3; i++) { %>
          <div class="repeat-row">
            <h4>Employer <%= i + 1 %><%= i === 0 ? ' (most recent)' : '' %></h4>
            <div class="field-row">
              <div class="field"><label>Employer name</label><input type="text" name="emp_employerName_<%= i %>"></div>
              <div class="field"><label>Job title</label><input type="text" name="emp_jobTitle_<%= i %>"></div>
            </div>
            <div class="field"><label>Address</label><input type="text" name="emp_address_<%= i %>"></div>
            <div class="field-row">
              <div class="field"><label>Dates employed — from</label><input type="text" name="emp_datesFrom_<%= i %>" placeholder="MM/YYYY"></div>
              <div class="field"><label>to</label><input type="text" name="emp_datesTo_<%= i %>" placeholder="MM/YYYY"></div>
            </div>
            <div class="field"><label>Describe work performed</label><textarea name="emp_workPerformed_<%= i %>"></textarea></div>
            <div class="field"><label>Immediate supervisor's name and title</label><input type="text" name="emp_supervisor_<%= i %>"></div>
            <div class="field">
              <label>May we contact this employer?</label>
              <div class="radio-group">
                <label><input type="radio" name="emp_mayContact_<%= i %>" value="yes"> Yes</label>
                <label><input type="radio" name="emp_mayContact_<%= i %>" value="no"> No</label>
              </div>
            </div>
            <div class="field"><label>Reason for leaving or seeking other employment</label><textarea name="emp_reasonLeaving_<%= i %>"></textarea></div>
          </div>
        <% } %>
        <div class="field"><label for="volunteerWorkHistory">List any verified work performed on a volunteer basis</label><textarea id="volunteerWorkHistory" name="volunteerWorkHistory"><%= values.volunteerWorkHistory || '' %></textarea></div>

        <div class="form-section-title">Education</div>
        <% EDUCATION_LEVELS.forEach(function(level, i) { %>
          <div class="repeat-row">
            <h4><%= level %></h4>
            <div class="field-row">
              <div class="field"><label>Name &amp; location of school</label><input type="text" name="edu_school_<%= i %>"></div>
              <div class="field"><label>Dates attended</label><input type="text" name="edu_dates_<%= i %>"></div>
            </div>
            <div class="field-row">
              <div class="field"><label>Diploma / degree / certificate</label><input type="text" name="edu_diploma_<%= i %>"></div>
              <div class="field">
                <label>Did you graduate?</label>
                <div class="radio-group">
                  <label><input type="radio" name="edu_graduated_<%= i %>" value="yes"> Yes</label>
                  <label><input type="radio" name="edu_graduated_<%= i %>" value="no"> No</label>
                </div>
              </div>
            </div>
          </div>
        <% }); %>
        <div class="field"><label for="specializedTraining">Specialized training, apprenticeship license, foreign language skills, extracurricular activities</label><textarea id="specializedTraining" name="specializedTraining"><%= values.specializedTraining || '' %></textarea></div>

        <div class="form-section-title">Computer Skills</div>
        <table class="data-table skills-table u-mb-10">
          <thead><tr><th>Skill</th><th>Beginner</th><th>Intermediate</th><th>Advanced</th></tr></thead>
          <tbody>
          <% COMPUTER_SKILLS.forEach(function(skill) { %>
            <tr>
              <td><%= skill %></td>
              <td><input type="radio" name="skill_<%= skill %>" value="Beginner" aria-label="<%= skill %> beginner"></td>
              <td><input type="radio" name="skill_<%= skill %>" value="Intermediate" aria-label="<%= skill %> intermediate"></td>
              <td><input type="radio" name="skill_<%= skill %>" value="Advanced" aria-label="<%= skill %> advanced"></td>
            </tr>
          <% }); %>
          </tbody>
        </table>

        <div class="field">
          <label for="resume">Resume (optional) — PDF or Word, up to <%= maxUploadMb %>MB</label>
          <input type="file" id="resume" name="resume" accept=".pdf,.doc,.docx,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document">
        </div>

        <div class="form-section-title">References</div>
        <p class="hint">Please supply name, address, and phone number of three (3) references who are not related to you.</p>
        <% for (let i = 0; i < 3; i++) { %>
          <div class="repeat-row">
            <h4>Reference <%= i + 1 %></h4>
            <div class="field-row">
              <div class="field"><label>Name</label><input type="text" name="ref_name_<%= i %>"></div>
              <div class="field"><label>Phone</label><input type="tel" name="ref_phone_<%= i %>"></div>
            </div>
            <div class="field"><label>Address</label><input type="text" name="ref_address_<%= i %>"></div>
          </div>
        <% } %>

        <div class="form-section-title">Applicant's Acknowledgement</div>
        <div class="alert alert-info">
          It is unlawful in Massachusetts to require or administer a lie detector test as a condition of employment. I authorize present and former employers, educational institutions, and references to disclose relevant information to the Town, and release all parties from liability for such disclosure. I certify that all information provided is true, accurate, and complete to the best of my knowledge. I understand an offer of employment may be conditioned on a medical screening exam, pre-employment drug screening, criminal records check, and/or background check, and that any appointment is probationary and at-will unless otherwise stated in a collective bargaining agreement.
        </div>
        <div class="field-row">
          <div class="field <%= errors.signatureTypedName ? 'has-error' : '' %>">
            <label for="signatureTypedName">Type your full legal name as your signature *</label>
            <input type="text" id="signatureTypedName" name="signatureTypedName" required value="<%= values.signatureTypedName || '' %>">
            <% if (errors.signatureTypedName) { %><div class="field-error"><%= errors.signatureTypedName.msg %></div><% } %>
          </div>
        </div>
        <div class="field <%= errors.acknowledged ? 'has-error' : '' %>">
          <label><input type="checkbox" name="acknowledged" required> I have read and fully understand the above and seek employment under these conditions. *</label>
          <% if (errors.acknowledged) { %><div class="field-error"><%= errors.acknowledged.msg %></div><% } %>
        </div>

        <button class="btn btn-primary" type="submit">Submit Employment Application</button>
      </form>
    </div>
  </div>
</section>
