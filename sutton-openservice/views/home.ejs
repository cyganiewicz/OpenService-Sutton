<section class="hero">
  <div class="wrap">
    <div class="eyebrow">Volunteer &amp; Employment Portal</div>
    <h1>Serve the Town of Sutton.</h1>
    <p class="lead">OpenService is the companion to OpenBook — a clear, direct way to see current volunteer seats on Town boards and commissions, open department jobs, and who currently holds each appointed seat.</p>
    <div class="cta-row">
      <a class="btn btn-primary" href="/vacancies">View Current Vacancies</a>
      <a class="btn btn-outline" href="/board-members">See Board &amp; Commission Terms</a>
    </div>
  </div>
</section>

<section class="section">
  <div class="wrap">
    <div class="card-grid">
      <div class="card stat-card">
        <div class="stat-num"><%= openVacancyCount %></div>
        <div class="stat-label">Open vacancies right now</div>
      </div>
      <div class="card stat-card">
        <div class="stat-num"><%= boardCount %></div>
        <div class="stat-label">Boards &amp; commissions tracked</div>
      </div>
      <div class="card stat-card">
        <div class="stat-num">2</div>
        <div class="stat-label">Ways to apply — volunteer or employment</div>
      </div>
    </div>
  </div>
</section>

<section class="section" style="padding-top:0;">
  <div class="wrap">
    <h2 class="section-title">Two ways to get involved</h2>
    <p class="section-sub">Choose the application that matches the opportunity.</p>
    <div class="card-grid">
      <div class="card">
        <span class="badge badge-board">Boards &amp; Commissions</span>
        <h3 style="margin-top:10px;">Volunteer Application</h3>
        <p>Apply for an appointed seat on a Town board or commission — Planning Board, Conservation Commission, and more.</p>
        <a class="btn btn-navy btn-sm" href="/volunteer-application">Start Volunteer Application</a>
      </div>
      <div class="card">
        <span class="badge badge-dept">Town Departments</span>
        <h3 style="margin-top:10px;">Employment Application</h3>
        <p>Apply for a paid, full-time, part-time, or seasonal position with a Town department.</p>
        <a class="btn btn-navy btn-sm" href="/employment-application">Start Employment Application</a>
      </div>
    </div>
  </div>
</section>

<% if (recentVacancies.length) { %>
<section class="section" style="padding-top:0;">
  <div class="wrap">
    <h2 class="section-title">Recently Posted</h2>
    <div class="card-grid">
      <% recentVacancies.forEach(function(v) { %>
        <div class="card">
          <span class="badge <%= v.category === 'BOARD_COMMISSION' ? 'badge-board' : 'badge-dept' %>">
            <%= v.category === 'BOARD_COMMISSION' ? 'Board / Commission' : 'Town Department' %>
          </span>
          <h3 style="margin-top:10px;"><%= v.title %></h3>
          <p><%= v.departmentOrBoard %></p>
          <a class="btn btn-sm btn-outline" style="color:#16294a;border-color:#16294a;" href="/vacancies"><%= 'View details' %></a>
        </div>
      <% }); %>
    </div>
  </div>
</section>
<% } %>
