<div class="admin-sidebar">
  <a href="/admin" class="<%= currentPath === '/admin' ? 'active' : '' %>">Dashboard</a>
  <a href="/admin/vacancies" class="<%= currentPath.startsWith('/admin/vacancies') ? 'active' : '' %>">Vacancies</a>
  <a href="/admin/boards" class="<%= currentPath.startsWith('/admin/boards') ? 'active' : '' %>">Boards &amp; Members</a>
  <a href="/admin/applications/volunteer" class="<%= currentPath.startsWith('/admin/applications/volunteer') ? 'active' : '' %>">Volunteer Applications</a>
  <a href="/admin/applications/employment" class="<%= currentPath.startsWith('/admin/applications/employment') ? 'active' : '' %>">Employment Applications</a>
  <a href="/admin/forms" class="<%= currentPath.startsWith('/admin/forms') ? 'active' : '' %>">Application Forms</a>
  <% if (adminUser && adminUser.role === 'ADMINISTRATOR') { %>
    <a href="/admin/staff" class="<%= currentPath.startsWith('/admin/staff') ? 'active' : '' %>">Staff Accounts</a>
  <% } %>
  <a href="/admin/account/password" class="<%= currentPath.startsWith('/admin/account/password') ? 'active' : '' %>">Change Password</a>
  <form method="POST" action="/admin/logout" class="u-mt-16">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <button class="btn btn-sm btn-outline-brand u-w-100" type="submit">Log Out</button>
  </form>
</div>
