<div class="admin-shell">
  <%- include('../partials/admin-sidebar') %>
  <div class="admin-content">
    <h1 class="section-title">Edit Employment Application</h1>
    <div class="form-shell" style="margin:0;max-width:none;">
      <% if (errors && errors.general) { %><div class="alert alert-error"><%= errors.general.msg %></div><% } %>
      <div class="alert alert-info">Editing here updates the applicant's contact info and history. Their original signature, acknowledgement date, and uploaded resume are preserved and are not changed by this form.</div>
      <% if (hasResume) { %>
        <p><a class="btn btn-sm btn-navy" href="/admin/applications/employment/<%= appId %>/resume">Download current resume: <%= resumeFileName %></a></p>
      <% } %>

      <form method="POST" action="/admin/applications/employment/<%= appId %>/edit" novalidate>
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">

        <% if (vacancies.length) { %>
        <div class="field">
          <label for="vacancyId">Position applying for</label>
          <select id="vacancyId" name="vacancyId">
            <option value="">— General application (no specific posting) —</option>
            <% vacancies.forEach(function(v) { %>
              <option value="<%= v.id %>" <%= values.vacancyId === v.id ? 'selected' : '' %>><%= v.title %> (<%= v.departmentOrBoard %>)</option>
            <% }); %>
          </select>
        </div>
        <% } %>

        <div class="field">
          <label for="referralSource">Referral source</label>
          <input type="text" id="referralSource" name="referralSource" value="<%= values.referralSource || '' %>">
        </div>

        <div class="form-section-title">Section I: Personal Information</div>
        <div class="field-row">
          <div class="field <%= errors.lastName ? 'has-error' : '' %>"><label for="lastName">Last name *</label><input type="text" id="lastName" name="lastName" required value="<%= values.lastName || '' %>"></div>
          <div class="field <%= errors.firstName ? 'has-error' : '' %>"><label for="firstName">First name *</label><input type="text" id="firstName" name="firstName" required value="<%= values.firstName || '' %>"></div>
          <div class="field"><label for="middleName">Middle name</label><input type="text" id="middleName" name="middleName" value="<%= values.middleName || '' %>"></div>
        </div>
        <div class="field <%= errors.addressStreet ? 'has-error' : '' %>"><label for="addressStreet">Street address *</label><input type="text" id="addressStreet" name="addressStreet" required value="<%= values.addressStreet || '' %>"></div>
        <div class="field-row">
          <div class="field <%= errors.addressCity ? 'has-error' : '' %>"><label for="addressCity">Town/City *</label><input type="text" id="addressCity" name="addressCity" required value="<%= values.addressCity || '' %>"></div>
          <div class="field"><label for="addressState">State</label><input type="text" id="addressState" name="addressState" maxlength="2" value="<%= values.addressState || 'MA' %>"></div>
          <div class="field <%= errors.addressZip ? 'has-error' : '' %>"><label for="addressZip">ZIP *</label><input type="text" id="addressZip" name="addressZip" required value="<%= values.addressZip || '' %>"></div>
        </div>
        <div class="field-row">
          <div class="field <%= errors.email ? 'has-error' : '' %>"><label for="email">Email *</label><input type="email" id="email" name="email" required value="<%= values.email || '' %>"></div>
          <div class="field"><label for="phoneHome">Home phone</label><input type="tel" id="phoneHome" name="phoneHome" value="<%= values.phoneHome || '' %>"></div>
          <div class="field"><label for="phoneCell">Cell phone</label><input type="tel" id="phoneCell" name="phoneCell" value="<%= values.phoneCell || '' %>"></div>
        </div>

        <div class="field <%= errors.workEligible ? 'has-error' : '' %>">
          <label>Proof of citizenship / legal right to work? *</label>
          <div class="radio-group">
            <label><input type="radio" name="workEligible" value="yes" required <%= values.workEligible==='yes'?'checked':'' %>> Yes</label>
            <label><input type="radio" name="workEligible" value="no" <%= values.workEligible==='no'?'checked':'' %>> No</label>
          </div>
        </div>
        <div class="field <%= errors.ageEighteenOrOlder ? 'has-error' : '' %>">
          <label>18 years or older? *</label>
          <div class="radio-group">
            <label><input type="radio" name="ageEighteenOrOlder" value="yes" required <%= values.ageEighteenOrOlder==='yes'?'checked':'' %>> Yes</label>
            <label><input type="radio" name="ageEighteenOrOlder" value="no" <%= values.ageEighteenOrOlder==='no'?'checked':'' %>> No</label>
          </div>
        </div>
        <div class="field <%= errors.workedForTownBefore ? 'has-error' : '' %>">
          <label>Worked for the Town before? *</label>
          <div class="radio-group">
            <label><input type="radio" name="workedForTownBefore" value="yes" required <%= values.workedForTownBefore==='yes'?'checked':'' %>> Yes</label>
            <label><input type="radio" name="workedForTownBefore" value="no" <%= values.workedForTownBefore==='no'?'checked':'' %>> No</label>
          </div>
        </div>
        <div class="field-row">
          <div class="field"><label for="priorEmploymentFrom">If yes — from</label><input type="text" id="priorEmploymentFrom" name="priorEmploymentFrom" value="<%= values.priorEmploymentFrom || '' %>"></div>
          <div class="field"><label for="priorEmploymentTo">to</label><input type="text" id="priorEmploymentTo" name="priorEmploymentTo" value="<%= values.priorEmploymentTo || '' %>"></div>
          <div class="field"><label for="priorDepartment">Which department</label><input type="text" id="priorDepartment" name="priorDepartment" value="<%= values.priorDepartment || '' %>"></div>
        </div>
        <div class="field <%= errors.capableOfDuties ? 'has-error' : '' %>">
          <label>Capable of performing all duties? *</label>
          <div class="radio-group">
            <label><input type="radio" name="capableOfDuties" value="yes" required <%= values.capableOfDuties==='yes'?'checked':'' %>> Yes</label>
            <label><input type="radio" name="capableOfDuties" value="no" <%= values.capableOfDuties==='no'?'checked':'' %>> No</label>
          </div>
        </div>
        <div class="field"><label for="incapableDutiesDetail">If no, which duty(ies)?</label><input type="text" id="incapableDutiesDetail" name="incapableDutiesDetail" value="<%= values.incapableDutiesDetail || '' %>"></div>
        <div class="field-row">
          <div class="field <%= errors.currentlyEmployed ? 'has-error' : '' %>">
            <label>Currently employed? *</label>
            <div class="radio-group">
              <label><input type="radio" name="currentlyEmployed" value="yes" required <%= values.currentlyEmployed==='yes'?'checked':'' %>> Yes</label>
              <label><input type="radio" name="currentlyEmployed" value="no" <%= values.currentlyEmployed==='no'?'checked':'' %>> No</label>
            </div>
          </div>
          <div class="field <%= errors.onLayoffRecall ? 'has-error' : '' %>">
            <label>On layoff, subject to recall? *</label>
            <div class="radio-group">
              <label><input type="radio" name="onLayoffRecall" value="yes" required <%= values.onLayoffRecall==='yes'?'checked':'' %>> Yes</label>
              <label><input type="radio" name="onLayoffRecall" value="no" <%= values.onLayoffRecall==='no'?'checked':'' %>> No</label>
            </div>
          </div>
        </div>

        <div class="form-section-title">Section II: Employment History</div>
        <% for (let i = 0; i < 3; i++) { %>
          <div class="repeat-row">
            <h4>Employer <%= i + 1 %></h4>
            <div class="field-row">
              <div class="field"><label>Employer name</label><input type="text" name="emp_employerName_<%= i %>" value="<%= values['emp_employerName_' + i] || '' %>"></div>
              <div class="field"><label>Job title</label><input type="text" name="emp_jobTitle_<%= i %>" value="<%= values['emp_jobTitle_' + i] || '' %>"></div>
            </div>
            <div class="field"><label>Address</label><input type="text" name="emp_address_<%= i %>" value="<%= values['emp_address_' + i] || '' %>"></div>
            <div class="field-row">
              <div class="field"><label>Dates — from</label><input type="text" name="emp_datesFrom_<%= i %>" value="<%= values['emp_datesFrom_' + i] || '' %>"></div>
              <div class="field"><label>to</label><input type="text" name="emp_datesTo_<%= i %>" value="<%= values['emp_datesTo_' + i] || '' %>"></div>
            </div>
            <div class="field"><label>Work performed</label><textarea name="emp_workPerformed_<%= i %>"><%= values['emp_workPerformed_' + i] || '' %></textarea></div>
            <div class="field"><label>Supervisor name/title</label><input type="text" name="emp_supervisor_<%= i %>" value="<%= values['emp_supervisor_' + i] || '' %>"></div>
            <div class="field">
              <label>May we contact this employer?</label>
              <div class="radio-group">
                <label><input type="radio" name="emp_mayContact_<%= i %>" value="yes" <%= values['emp_mayContact_' + i]==='yes'?'checked':'' %>> Yes</label>
                <label><input type="radio" name="emp_mayContact_<%= i %>" value="no" <%= values['emp_mayContact_' + i]==='no'?'checked':'' %>> No</label>
              </div>
            </div>
            <div class="field"><label>Reason for leaving</label><textarea name="emp_reasonLeaving_<%= i %>"><%= values['emp_reasonLeaving_' + i] || '' %></textarea></div>
          </div>
        <% } %>
        <div class="field"><label for="volunteerWorkHistory">Verified volunteer work</label><textarea id="volunteerWorkHistory" name="volunteerWorkHistory"><%= values.volunteerWorkHistory || '' %></textarea></div>

        <div class="form-section-title">Section III: Education</div>
        <% EDUCATION_LEVELS.forEach(function(level, i) { %>
          <div class="repeat-row">
            <h4><%= level %></h4>
            <div class="field-row">
              <div class="field"><label>School name &amp; location</label><input type="text" name="edu_school_<%= i %>" value="<%= values['edu_school_' + i] || '' %>"></div>
              <div class="field"><label>Dates attended</label><input type="text" name="edu_dates_<%= i %>" value="<%= values['edu_dates_' + i] || '' %>"></div>
            </div>
            <div class="field-row">
              <div class="field"><label>Diploma/degree</label><input type="text" name="edu_diploma_<%= i %>" value="<%= values['edu_diploma_' + i] || '' %>"></div>
              <div class="field">
                <label>Graduated?</label>
                <div class="radio-group">
                  <label><input type="radio" name="edu_graduated_<%= i %>" value="yes" <%= values['edu_graduated_' + i]==='yes'?'checked':'' %>> Yes</label>
                  <label><input type="radio" name="edu_graduated_<%= i %>" value="no" <%= values['edu_graduated_' + i]==='no'?'checked':'' %>> No</label>
                </div>
              </div>
            </div>
          </div>
        <% }); %>
        <div class="field"><label for="specializedTraining">Specialized training / skills</label><textarea id="specializedTraining" name="specializedTraining"><%= values.specializedTraining || '' %></textarea></div>
        <div class="field"><label for="additionalInfo">Additional information</label><textarea id="additionalInfo" name="additionalInfo"><%= values.additionalInfo || '' %></textarea></div>

        <div class="form-section-title">Section IV: Computer Skills</div>
        <table class="data-table skills-table" style="margin-bottom:10px;">
          <thead><tr><th>Skill</th><th>Beginner</th><th>Intermediate</th><th>Advanced</th></tr></thead>
          <tbody>
          <% COMPUTER_SKILLS.forEach(function(skill) { %>
            <tr>
              <td><%= skill %></td>
              <td><input type="radio" name="skill_<%= skill %>" value="Beginner" <%= values['skill_' + skill]==='Beginner'?'checked':'' %>></td>
              <td><input type="radio" name="skill_<%= skill %>" value="Intermediate" <%= values['skill_' + skill]==='Intermediate'?'checked':'' %>></td>
              <td><input type="radio" name="skill_<%= skill %>" value="Advanced" <%= values['skill_' + skill]==='Advanced'?'checked':'' %>></td>
            </tr>
          <% }); %>
          </tbody>
        </table>

        <div class="form-section-title">Section V: Military History</div>
        <div class="field">
          <label>Veteran?</label>
          <div class="radio-group">
            <label><input type="radio" name="veteran" value="yes" <%= values.veteran==='yes'?'checked':'' %>> Yes</label>
            <label><input type="radio" name="veteran" value="no" <%= values.veteran!=='yes'?'checked':'' %>> No</label>
          </div>
        </div>
        <div class="field-row">
          <div class="field"><label for="militaryBranch">Branch</label><input type="text" id="militaryBranch" name="militaryBranch" value="<%= values.militaryBranch || '' %>"></div>
          <div class="field"><label for="militaryRankDischarged">Rank when discharged</label><input type="text" id="militaryRankDischarged" name="militaryRankDischarged" value="<%= values.militaryRankDischarged || '' %>"></div>
          <div class="field"><label for="militaryDischargeStatus">Discharge status</label><input type="text" id="militaryDischargeStatus" name="militaryDischargeStatus" value="<%= values.militaryDischargeStatus || '' %>"></div>
        </div>
        <div class="field"><label for="presentMilitaryStatus">Present military status</label><input type="text" id="presentMilitaryStatus" name="presentMilitaryStatus" value="<%= values.presentMilitaryStatus || '' %>"></div>
        <div class="field"><label for="militaryServiceSchool">Service school / special experience</label><textarea id="militaryServiceSchool" name="militaryServiceSchool"><%= values.militaryServiceSchool || '' %></textarea></div>

        <div class="form-section-title">Section VI: References &amp; Miscellaneous</div>
        <div class="field"><label for="civicActivities">Civic activities</label><textarea id="civicActivities" name="civicActivities"><%= values.civicActivities || '' %></textarea></div>
        <% for (let i = 0; i < 3; i++) { %>
          <div class="repeat-row">
            <h4>Reference <%= i + 1 %></h4>
            <div class="field-row">
              <div class="field"><label>Name</label><input type="text" name="ref_name_<%= i %>" value="<%= values['ref_name_' + i] || '' %>"></div>
              <div class="field"><label>Phone</label><input type="tel" name="ref_phone_<%= i %>" value="<%= values['ref_phone_' + i] || '' %>"></div>
            </div>
            <div class="field"><label>Address</label><input type="text" name="ref_address_<%= i %>" value="<%= values['ref_address_' + i] || '' %>"></div>
          </div>
        <% } %>

        <div class="form-section-title">Section VII: Acknowledgement (read-only)</div>
        <div class="field-row">
          <div class="field"><label>Signed name</label><input type="text" value="<%= values.signatureTypedName %>" disabled></div>
        </div>
        <p class="hint">Not editable here — this reflects the applicant's original submission.</p>

        <button class="btn btn-primary" type="submit">Save Changes</button>
        <a class="btn btn-outline" style="color:#16294a;border-color:#16294a;" href="/admin/applications/employment/<%= appId %>">Cancel</a>
      </form>
    </div>
  </div>
</div>
