<div class="admin-shell">
  <%- include('../partials/admin-sidebar') %>
  <div class="admin-content">
    <h1 class="section-title">Edit Employment Application</h1>
    <div class="form-shell form-shell-flush">
      <% if (errors && errors.general) { %><div class="alert alert-error"><%= errors.general.msg %></div><% } %>
      <div class="alert alert-info">Editing here updates the applicant's answers and history. Their original signature, acknowledgement date, and uploaded resume are preserved and aren't changed by this form.</div>
      <% if (hasResume) { %>
        <p><a class="btn btn-sm btn-navy" href="/admin/applications/employment/<%= appId %>/resume">Download current resume: <%= resumeFileName %></a></p>
      <% } %>

      <form method="POST" action="/admin/applications/employment/<%= appId %>/edit" novalidate>
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">

        <% if (vacancies.length) { %>
        <div class="field">
          <label for="vacancyId">Position applying for</label>
          <select id="vacancyId" name="vacancyId">
            <option value="">— General application (no specific posting) —</option>
            <% vacancies.forEach(function(v) { %>
              <option value="<%= v.id %>" <%= vacancyId === v.id ? 'selected' : '' %>><%= v.title %> (<%= v.departmentOrBoard %>)</option>
            <% }); %>
          </select>
        </div>
        <% } %>

        <% fields.forEach(function (field) { %>
          <%- include('../partials/dynamic-field', { field: field, value: values[field.name], error: errors[field.name] }) %>
        <% }); %>

        <div class="form-section-title">Employment History</div>
        <% for (let i = 0; i < 3; i++) { %>
          <div class="repeat-row">
            <h4>Employer <%= i + 1 %></h4>
            <div class="field-row">
              <div class="field"><label>Employer name</label><input type="text" name="emp_employerName_<%= i %>" value="<%= values['emp_employerName_' + i] || '' %>"></div>
              <div class="field"><label>Job title</label><input type="text" name="emp_jobTitle_<%= i %>" value="<%= values['emp_jobTitle_' + i] || '' %>"></div>
            </div>
            <div class="field"><label>Address</label><input type="text" name="emp_address_<%= i %>" value="<%= values['emp_address_' + i] || '' %>"></div>
            <div class="field-row">
              <div class="field"><label>Dates — from</label><input type="text" name="emp_datesFrom_<%= i %>" value="<%= values['emp_datesFrom_' + i] || '' %>"></div>
              <div class="field"><label>to</label><input type="text" name="emp_datesTo_<%= i %>" value="<%= values['emp_datesTo_' + i] || '' %>"></div>
            </div>
            <div class="field"><label>Work performed</label><textarea name="emp_workPerformed_<%= i %>"><%= values['emp_workPerformed_' + i] || '' %></textarea></div>
            <div class="field"><label>Supervisor name/title</label><input type="text" name="emp_supervisor_<%= i %>" value="<%= values['emp_supervisor_' + i] || '' %>"></div>
            <div class="field">
              <label>May we contact this employer?</label>
              <div class="radio-group">
                <label><input type="radio" name="emp_mayContact_<%= i %>" value="yes" <%= values['emp_mayContact_' + i]==='yes'?'checked':'' %>> Yes</label>
                <label><input type="radio" name="emp_mayContact_<%= i %>" value="no" <%= values['emp_mayContact_' + i]==='no'?'checked':'' %>> No</label>
              </div>
            </div>
            <div class="field"><label>Reason for leaving</label><textarea name="emp_reasonLeaving_<%= i %>"><%= values['emp_reasonLeaving_' + i] || '' %></textarea></div>
          </div>
        <% } %>
        <div class="field"><label for="volunteerWorkHistory">Verified volunteer work</label><textarea id="volunteerWorkHistory" name="volunteerWorkHistory"><%= values.volunteerWorkHistory || '' %></textarea></div>

        <div class="form-section-title">Education</div>
        <% EDUCATION_LEVELS.forEach(function(level, i) { %>
          <div class="repeat-row">
            <h4><%= level %></h4>
            <div class="field-row">
              <div class="field"><label>School name &amp; location</label><input type="text" name="edu_school_<%= i %>" value="<%= values['edu_school_' + i] || '' %>"></div>
              <div class="field"><label>Dates attended</label><input type="text" name="edu_dates_<%= i %>" value="<%= values['edu_dates_' + i] || '' %>"></div>
            </div>
            <div class="field-row">
              <div class="field"><label>Diploma/degree</label><input type="text" name="edu_diploma_<%= i %>" value="<%= values['edu_diploma_' + i] || '' %>"></div>
              <div class="field">
                <label>Graduated?</label>
                <div class="radio-group">
                  <label><input type="radio" name="edu_graduated_<%= i %>" value="yes" <%= values['edu_graduated_' + i]==='yes'?'checked':'' %>> Yes</label>
                  <label><input type="radio" name="edu_graduated_<%= i %>" value="no" <%= values['edu_graduated_' + i]==='no'?'checked':'' %>> No</label>
                </div>
              </div>
            </div>
          </div>
        <% }); %>
        <div class="field"><label for="specializedTraining">Specialized training / skills</label><textarea id="specializedTraining" name="specializedTraining"><%= values.specializedTraining || '' %></textarea></div>

        <div class="form-section-title">Computer Skills</div>
        <table class="data-table skills-table u-mb-10">
          <thead><tr><th>Skill</th><th>Beginner</th><th>Intermediate</th><th>Advanced</th></tr></thead>
          <tbody>
          <% COMPUTER_SKILLS.forEach(function(skill) { %>
            <tr>
              <td><%= skill %></td>
              <td><input type="radio" name="skill_<%= skill %>" value="Beginner" <%= values['skill_' + skill]==='Beginner'?'checked':'' %>></td>
              <td><input type="radio" name="skill_<%= skill %>" value="Intermediate" <%= values['skill_' + skill]==='Intermediate'?'checked':'' %>></td>
              <td><input type="radio" name="skill_<%= skill %>" value="Advanced" <%= values['skill_' + skill]==='Advanced'?'checked':'' %>></td>
            </tr>
          <% }); %>
          </tbody>
        </table>

        <div class="form-section-title">References</div>
        <% for (let i = 0; i < 3; i++) { %>
          <div class="repeat-row">
            <h4>Reference <%= i + 1 %></h4>
            <div class="field-row">
              <div class="field"><label>Name</label><input type="text" name="ref_name_<%= i %>" value="<%= values['ref_name_' + i] || '' %>"></div>
              <div class="field"><label>Phone</label><input type="tel" name="ref_phone_<%= i %>" value="<%= values['ref_phone_' + i] || '' %>"></div>
            </div>
            <div class="field"><label>Address</label><input type="text" name="ref_address_<%= i %>" value="<%= values['ref_address_' + i] || '' %>"></div>
          </div>
        <% } %>

        <div class="form-section-title">Acknowledgement (read-only)</div>
        <div class="field-row">
          <div class="field"><label>Signed name</label><input type="text" value="<%= values.signatureTypedName || '' %>" disabled></div>
        </div>
        <p class="hint">Not editable here — this reflects the applicant's original submission.</p>

        <button class="btn btn-primary" type="submit">Save Changes</button>
        <a class="btn btn-outline-brand" href="/admin/applications/employment/<%= appId %>">Cancel</a>
      </form>
    </div>
  </div>
</div>
