<div class="admin-shell">
  <%- include('../partials/admin-sidebar') %>
  <div class="admin-content">
    <h1 class="section-title"><%= vacancy ? 'Edit Vacancy' : 'New Vacancy' %></h1>
    <div class="form-shell" style="margin:0;max-width:none;">
      <form method="POST" action="<%= vacancy ? '/admin/vacancies/' + vacancy.id + '/edit' : '/admin/vacancies/new' %>">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="field"><label>Title *</label><input type="text" name="title" required value="<%= vacancy ? vacancy.title : '' %>"></div>
        <div class="field-row">
          <div class="field">
            <label>Category *</label>
            <select name="category" required>
              <option value="BOARD_COMMISSION" <%= vacancy && vacancy.category==='BOARD_COMMISSION' ? 'selected':'' %>>Board / Commission</option>
              <option value="TOWN_DEPARTMENT" <%= vacancy && vacancy.category==='TOWN_DEPARTMENT' ? 'selected':'' %>>Town Department</option>
            </select>
          </div>
          <div class="field">
            <label>Employment Type *</label>
            <select name="employmentType" required>
              <% ['FULL_TIME','PART_TIME','SEASONAL','APPOINTED','VOLUNTEER'].forEach(function(t){ %>
                <option value="<%= t %>" <%= vacancy && vacancy.employmentType===t ? 'selected':'' %>><%= t.replace('_',' ') %></option>
              <% }); %>
            </select>
          </div>
          <div class="field">
            <label>Status *</label>
            <select name="status" required>
              <option value="OPEN" <%= vacancy && vacancy.status==='OPEN' ? 'selected':'' %>>Open</option>
              <option value="CLOSED" <%= vacancy && vacancy.status==='CLOSED' ? 'selected':'' %>>Closed</option>
            </select>
          </div>
        </div>
        <div class="field"><label>Department or Board Name *</label><input type="text" name="departmentOrBoard" required value="<%= vacancy ? vacancy.departmentOrBoard : '' %>"></div>
        <div class="field">
          <label>Linked Board/Commission (optional — used to cross-reference seats)</label>
          <select name="boardCommissionId">
            <option value="">— None —</option>
            <% boards.forEach(function(b){ %>
              <option value="<%= b.id %>" <%= vacancy && vacancy.boardCommissionId===b.id ? 'selected':'' %>><%= b.name %></option>
            <% }); %>
          </select>
        </div>
        <div class="field"><label>Description *</label><textarea name="description" required><%= vacancy ? vacancy.description : '' %></textarea></div>
        <div class="field"><label>Qualifications</label><textarea name="qualifications"><%= vacancy ? vacancy.qualifications : '' %></textarea></div>
        <%
          var closingDateStr = '';
          if (vacancy && vacancy.closingDate) {
            closingDateStr = vacancy.closingDate instanceof Date ? vacancy.closingDate.toISOString().slice(0,10) : String(vacancy.closingDate).slice(0,10);
          }
        %>
        <div class="field"><label>Closing date (optional)</label><input type="date" name="closingDate" value="<%= closingDateStr %>"></div>
        <button class="btn btn-primary" type="submit">Save Vacancy</button>
        <a class="btn btn-outline" style="color:#16294a;border-color:#16294a;" href="/admin/vacancies">Cancel</a>
      </form>
    </div>
  </div>
</div>
