<div class="admin-shell">
  <%- include('../partials/admin-sidebar') %>
  <div class="admin-content">
    <h1 class="section-title">Volunteer Applications</h1>
    <table class="data-table">
      <thead><tr><th>Name</th><th>Boards Interested</th><th>Submitted</th><th>Status</th><th></th></tr></thead>
      <tbody>
        <% apps.forEach(function(a) { %>
          <tr>
            <td><%= a.firstName %> <%= a.lastName %><br><span class="hint"><%= a.email %></span></td>
            <td><%= a.boardsInterestedIn %></td>
            <td><%= a.submittedAt.toLocaleString() %></td>
            <td><span class="badge badge-status"><%= a.status.replace('_',' ') %></span></td>
            <td><a class="btn btn-sm btn-navy" href="/admin/applications/volunteer/<%= a.id %>">View</a></td>
          </tr>
        <% }); %>
        <% if (!apps.length) { %><tr><td colspan="5">No volunteer applications yet.</td></tr><% } %>
      </tbody>
    </table>
  </div>
</div>
