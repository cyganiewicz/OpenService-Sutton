<div class="admin-shell">
  <%- include('../partials/admin-sidebar') %>
  <div class="admin-content">
    <h1 class="section-title">Change Password</h1>
    <% if (typeof forced !== 'undefined' && forced) { %>
      <div class="alert alert-info">You're using a temporary password. Choose a new one to continue.</div>
    <% } %>
    <% if (errors && errors.general) { %><div class="alert alert-error"><%= errors.general.msg %></div><% } %>
    <div class="form-shell form-shell-narrow">
      <form method="POST" action="/admin/account/password">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="field <%= errors.currentPassword ? 'has-error' : '' %>">
          <label for="currentPassword">Current password</label>
          <input type="password" id="currentPassword" name="currentPassword" required autocomplete="current-password">
          <% if (errors.currentPassword) { %><div class="field-error"><%= errors.currentPassword.msg %></div><% } %>
        </div>
        <div class="field <%= errors.newPassword ? 'has-error' : '' %>">
          <label for="newPassword">New password (at least 10 characters)</label>
          <input type="password" id="newPassword" name="newPassword" required minlength="10" autocomplete="new-password">
          <% if (errors.newPassword) { %><div class="field-error"><%= errors.newPassword.msg %></div><% } %>
        </div>
        <div class="field <%= errors.confirmPassword ? 'has-error' : '' %>">
          <label for="confirmPassword">Confirm new password</label>
          <input type="password" id="confirmPassword" name="confirmPassword" required minlength="10" autocomplete="new-password">
          <% if (errors.confirmPassword) { %><div class="field-error"><%= errors.confirmPassword.msg %></div><% } %>
        </div>
        <button class="btn btn-primary" type="submit">Update Password</button>
      </form>
    </div>
  </div>
</div>
