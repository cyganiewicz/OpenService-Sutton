<div class="admin-shell">
  <%- include('../partials/admin-sidebar') %>
  <div class="admin-content">
    <h1 class="section-title">Edit Volunteer Application</h1>
    <div class="form-shell form-shell-flush">
      <% if (errors && errors.general) { %><div class="alert alert-error"><%= errors.general.msg %></div><% } %>
      <form method="POST" action="/admin/applications/volunteer/<%= appId %>/edit">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">

        <% fields.forEach(function (field) { %>
          <%- include('../partials/dynamic-field', { field: field, value: values[field.name], error: errors[field.name] }) %>
        <% }); %>

        <% if (vacancies.length) { %>
        <div class="field">
          <label for="vacancyId">Linked vacancy</label>
          <select id="vacancyId" name="vacancyId">
            <option value="">— Not linked to a specific vacancy —</option>
            <% vacancies.forEach(function(v) { %>
              <option value="<%= v.id %>" <%= vacancyId === v.id ? 'selected' : '' %>><%= v.title %> (<%= v.departmentOrBoard %>)</option>
            <% }); %>
          </select>
        </div>
        <% } %>

        <button class="btn btn-primary" type="submit">Save Changes</button>
        <a class="btn btn-outline-brand" href="/admin/applications/volunteer/<%= appId %>">Cancel</a>
      </form>
    </div>
  </div>
</div>
