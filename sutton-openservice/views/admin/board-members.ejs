<div class="admin-shell">
  <%- include('../partials/admin-sidebar') %>
  <div class="admin-content">
    <h1 class="section-title">Boards &amp; Commissions</h1>

    <div class="card u-mb-24">
      <h3>Add a new board or commission</h3>
      <form method="POST" action="/admin/boards/new">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="field-row">
          <div class="field"><label>Name *</label><input type="text" name="name" required></div>
          <div class="field"><label>Total seats</label><input type="number" name="totalSeats" min="0" max="50" value="5"></div>
        </div>
        <div class="field"><label>Description</label><input type="text" name="description"></div>
        <button class="btn btn-primary btn-sm" type="submit">Add Board</button>
      </form>
    </div>

    <% boards.forEach(function(b) { %>
      <div class="card u-mb-22">
        <div class="admin-topbar u-mb-10">
          <h3 class="u-m-0"><%= b.name %> <span class="hint">(<%= b.seats.length %> seat record(s))</span></h3>
          <form method="POST" action="/admin/boards/<%= b.id %>/delete" data-confirm="Delete this board and all its seat records?">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button class="btn btn-sm btn-danger" type="submit">Delete Board</button>
          </form>
        </div>

        <%# Each row's edit/delete forms live outside the table (valid HTML —
            a <form> cannot legally wrap <td> elements) and are wired to their
            row's inputs via the form="..." attribute. %>
        <% b.seats.forEach(function(s) { %>
          <form id="edit-seat-<%= s.id %>" method="POST" action="/admin/boards/<%= b.id %>/seats/<%= s.id %>/edit">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          </form>
          <form id="delete-seat-<%= s.id %>" method="POST" action="/admin/boards/<%= b.id %>/seats/<%= s.id %>/delete" data-confirm="Delete this seat?">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          </form>
        <% }); %>

        <table class="data-table u-mb-14">
          <thead><tr><th>Seat</th><th>Member</th><th>Appointed</th><th>Term Expires</th><th>Vacant?</th><th></th></tr></thead>
          <tbody>
            <% b.seats.forEach(function(s) { %>
              <tr>
                <td><input type="text" name="seatTitle" form="edit-seat-<%= s.id %>" value="<%= s.seatTitle %>" class="u-w-100"></td>
                <td><input type="text" name="memberName" form="edit-seat-<%= s.id %>" value="<%= s.memberName || '' %>" class="u-w-100"></td>
                <td><input type="date" name="appointedDate" form="edit-seat-<%= s.id %>" value="<%= s.appointedDate ? s.appointedDate.toISOString().slice(0,10) : '' %>"></td>
                <td><input type="date" name="termExpires" form="edit-seat-<%= s.id %>" value="<%= s.termExpires ? s.termExpires.toISOString().slice(0,10) : '' %>"></td>
                <td class="u-text-center"><input type="checkbox" name="vacant" form="edit-seat-<%= s.id %>" <%= s.vacant ? 'checked' : '' %>></td>
                <td class="u-nowrap">
                  <button class="btn btn-sm btn-navy" type="submit" form="edit-seat-<%= s.id %>">Save</button>
                  <button class="btn btn-sm btn-danger" type="submit" form="delete-seat-<%= s.id %>">Delete</button>
                </td>
              </tr>
            <% }); %>
            <% if (!b.seats.length) { %><tr><td colspan="6">No seats recorded yet.</td></tr><% } %>
          </tbody>
        </table>

        <form method="POST" action="/admin/boards/<%= b.id %>/seats/new">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="field-row">
            <div class="field"><label>New seat title</label><input type="text" name="seatTitle" placeholder="e.g. Member, Chair, Alternate" required></div>
            <div class="field"><label>Member name (blank = vacant)</label><input type="text" name="memberName"></div>
            <div class="field"><label>Term expires</label><input type="date" name="termExpires"></div>
          </div>
          <button class="btn btn-sm btn-outline-brand" type="submit">+ Add Seat</button>
        </form>
      </div>
    <% }); %>
  </div>
</div>
