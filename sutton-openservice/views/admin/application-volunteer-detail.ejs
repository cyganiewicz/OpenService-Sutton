<div class="admin-shell">
  <%- include('../partials/admin-sidebar') %>
  <div class="admin-content">
    <div class="admin-topbar">
      <h1 class="section-title u-m-0"><%= app.responses.firstName || '' %> <%= app.responses.lastName || '' %></h1>
      <a class="btn btn-sm btn-navy" href="/admin/applications/volunteer/<%= app.id %>/edit">Edit Application</a>
    </div>
    <div class="detail-grid">
      <div class="detail-item"><div class="k">Submitted</div><div class="v"><%= app.submittedAt.toLocaleString() %></div></div>
      <div class="detail-item"><div class="k">Linked Vacancy</div><div class="v"><%= app.vacancy ? app.vacancy.title : '—' %></div></div>
    </div>

    <div class="card u-mb-16">
      <% fields.forEach(function (field) { %>
        <% if (field.fieldType === 'SECTION_HEADER') { %>
          <h3 class="u-mt-16"><%= field.label %></h3>
        <% } else if (field.fieldType !== 'PARAGRAPH') {
             var val = app.responses[field.name];
        %>
          <div class="detail-item u-mb-10">
            <div class="k"><%= field.label %></div>
            <div class="v">
              <% if (field.fieldType === 'CHECKBOX_GROUP') { %><%= Array.isArray(val) && val.length ? val.join(', ') : '—' %>
              <% } else if (field.fieldType === 'CHECKBOX_SINGLE') { %><%= val ? 'Yes' : 'No' %>
              <% } else { %><%= (val !== undefined && val !== null && val !== '') ? val : '—' %><% } %>
            </div>
          </div>
        <% } %>
      <% }); %>
    </div>

    <form method="POST" action="/admin/applications/volunteer/<%= app.id %>/status">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="field-row u-align-end">
        <div class="field">
          <label>Status</label>
          <select name="status">
            <% ['NEW','UNDER_REVIEW','INTERVIEWING','CLOSED'].forEach(function(s){ %>
              <option value="<%= s %>" <%= app.status===s?'selected':'' %>><%= s.replace('_',' ') %></option>
            <% }); %>
          </select>
        </div>
        <div class="field"><button class="btn btn-primary" type="submit">Update Status</button></div>
      </div>
    </form>
  </div>
</div>
