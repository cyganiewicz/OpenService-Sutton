<div class="admin-shell">
  <%- include('../partials/admin-sidebar') %>
  <div class="admin-content">
    <div class="admin-topbar">
      <h1 class="section-title u-m-0"><%= app.responses.firstName || '' %> <%= app.responses.lastName || '' %></h1>
      <a class="btn btn-sm btn-navy" href="/admin/applications/employment/<%= app.id %>/edit">Edit Application</a>
    </div>
    <div class="detail-grid">
      <div class="detail-item"><div class="k">Submitted</div><div class="v"><%= app.submittedAt.toLocaleString() %></div></div>
      <div class="detail-item"><div class="k">Position</div><div class="v"><%= app.vacancy ? app.vacancy.title : 'General application' %></div></div>
      <% if (app.resumeFileName) { %>
        <div class="detail-item"><div class="k">Resume</div><div class="v"><a href="/admin/applications/employment/<%= app.id %>/resume">Download (<%= app.resumeFileName %>)</a></div></div>
      <% } %>
    </div>

    <div class="card u-mb-16">
      <% fields.forEach(function (field) { %>
        <% if (field.fieldType === 'SECTION_HEADER') { %>
          <h3 class="u-mt-16"><%= field.label %></h3>
        <% } else if (field.fieldType !== 'PARAGRAPH') {
             var val = app.responses[field.name];
        %>
          <div class="detail-item u-mb-10">
            <div class="k"><%= field.label %></div>
            <div class="v">
              <% if (field.fieldType === 'CHECKBOX_GROUP') { %><%= Array.isArray(val) && val.length ? val.join(', ') : '—' %>
              <% } else if (field.fieldType === 'CHECKBOX_SINGLE') { %><%= val ? 'Yes' : 'No' %>
              <% } else { %><%= (val !== undefined && val !== null && val !== '') ? val : '—' %><% } %>
            </div>
          </div>
        <% } %>
      <% }); %>
    </div>

    <div class="card u-mb-16">
      <h3>Employment History</h3>
      <% if (!(app.employmentHistory || []).length) { %><p>None listed.</p><% } %>
      <% (app.employmentHistory || []).forEach(function (row) { %>
        <div class="repeat-row">
          <h4><%= row.jobTitle || '' %><%= row.jobTitle && row.employerName ? ' at ' : '' %><%= row.employerName || '(unnamed employer)' %></h4>
          <div class="hint"><%= row.datesFrom || '?' %> – <%= row.datesTo || '?' %><%= row.address ? ' · ' + row.address : '' %></div>
          <% if (row.workPerformed) { %><p><%= row.workPerformed %></p><% } %>
          <div class="hint">Supervisor: <%= row.supervisor || '—' %> · May contact: <%= row.mayContact === 'yes' ? 'Yes' : (row.mayContact === 'no' ? 'No' : '—') %></div>
          <% if (row.reasonLeaving) { %><div class="hint">Reason for leaving: <%= row.reasonLeaving %></div><% } %>
        </div>
      <% }); %>
      <h4 class="u-mt-14">Volunteer Work History</h4><p><%= app.volunteerWorkHistory || '—' %></p>
    </div>

    <div class="card u-mb-16">
      <h3>Education</h3>
      <table class="data-table">
        <thead><tr><th>Level</th><th>School</th><th>Dates</th><th>Diploma</th><th>Graduated</th></tr></thead>
        <tbody>
          <% (app.education || []).forEach(function (e) { %>
            <tr><td><%= e.level %></td><td><%= e.school || '—' %></td><td><%= e.dates || '—' %></td><td><%= e.diploma || '—' %></td><td><%= e.graduated ? 'Yes' : 'No' %></td></tr>
          <% }); %>
        </tbody>
      </table>
      <p class="u-mt-12"><strong>Specialized Training:</strong> <%= app.specializedTraining || '—' %></p>
    </div>

    <div class="card u-mb-16">
      <h3>Computer Skills</h3>
      <% var skills = app.computerSkills || {}; var skillKeys = Object.keys(skills); %>
      <% if (skillKeys.length) { %>
        <ul>
          <% skillKeys.forEach(function (k) { %><li><%= k %>: <%= skills[k] %></li><% }); %>
        </ul>
      <% } else { %><p>None indicated.</p><% } %>
    </div>

    <div class="card u-mb-16">
      <h3>References</h3>
      <% if (!(app.references || []).length) { %><p>None listed.</p><% } %>
      <% (app.references || []).forEach(function (r, i) { %>
        <p><%= i + 1 %>. <%= r.name || '—' %> — <%= r.address || '—' %> — <%= r.phone || '—' %></p>
      <% }); %>
    </div>

    <div class="card u-mb-16">
      <h3>Acknowledgement</h3>
      <p>Signed: <strong><%= app.signatureTypedName %></strong> on <%= app.signatureDate.toDateString() %> — Acknowledged: <%= app.acknowledged ? 'Yes' : 'No' %></p>
    </div>

    <form method="POST" action="/admin/applications/employment/<%= app.id %>/status">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="field-row u-align-end">
        <div class="field">
          <label>Status</label>
          <select name="status">
            <% ['NEW','UNDER_REVIEW','INTERVIEWING','CLOSED'].forEach(function(s){ %>
              <option value="<%= s %>" <%= app.status===s?'selected':'' %>><%= s.replace('_',' ') %></option>
            <% }); %>
          </select>
        </div>
        <div class="field"><button class="btn btn-primary" type="submit">Update Status</button></div>
      </div>
    </form>
  </div>
</div>
