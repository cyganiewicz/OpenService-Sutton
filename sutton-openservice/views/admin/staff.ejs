<div class="admin-shell">
  <%- include('../partials/admin-sidebar') %>
  <div class="admin-content">
    <h1 class="section-title">Staff Accounts</h1>
    <p class="section-sub">Administrators can add staff logins, reset passwords, and deactivate accounts. Staff can manage vacancies, boards/commissions, and applications, but can't reach this page.</p>

    <% if (generatedPassword) { %>
      <div class="alert alert-success">
        <strong>Temporary password for <%= generatedPassword.email %>:</strong>
        <code class="u-fs-15"><%= generatedPassword.password %></code>
        <div class="hint">Share this with them directly (not by unencrypted email, if possible) — it won't be shown again. They'll be required to set their own password on first login.</div>
      </div>
    <% } %>
    <% if (errors && errors.email) { %><div class="alert alert-error"><%= errors.email.msg %></div><% } %>
    <% if (errors && errors.name) { %><div class="alert alert-error"><%= errors.name.msg %></div><% } %>

    <div class="card u-mb-24">
      <h3>Add a staff account</h3>
      <form method="POST" action="/admin/staff/new">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="field-row">
          <div class="field"><label>Full name *</label><input type="text" name="name" required></div>
          <div class="field"><label>Email *</label><input type="email" name="email" required></div>
          <div class="field">
            <label>Role *</label>
            <select name="role" required>
              <option value="STAFF">Staff (vacancies, boards, applications)</option>
              <option value="ADMINISTRATOR">Administrator (also manages staff accounts)</option>
            </select>
          </div>
        </div>
        <button class="btn btn-primary btn-sm" type="submit">Create Account</button>
      </form>
    </div>

    <table class="data-table">
      <thead><tr><th>Name</th><th>Email</th><th>Role</th><th>Status</th><th>Last Login</th><th></th></tr></thead>
      <tbody>
        <% staff.forEach(function(s) { %>
          <tr>
            <td><%= s.name %></td>
            <td><%= s.email %></td>
            <td><%= s.role %></td>
            <td><span class="badge <%= s.active ? 'badge-filled' : 'badge-vacant' %>"><%= s.active ? 'Active' : 'Deactivated' %></span></td>
            <td><%= s.lastLoginAt ? s.lastLoginAt.toLocaleString() : 'Never' %></td>
            <td class="u-nowrap">
              <% if (s.id !== adminUser.id) { %>
                <form method="POST" action="/admin/staff/<%= s.id %>/toggle-active" class="u-inline">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button class="btn btn-sm btn-outline-brand" type="submit"><%= s.active ? 'Deactivate' : 'Reactivate' %></button>
                </form>
              <% } %>
              <form method="POST" action="/admin/staff/<%= s.id %>/reset-password" class="u-inline" data-confirm="Reset the password for <%= s.email %>? They will need the new temporary password to log in.">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button class="btn btn-sm btn-outline-brand" type="submit">Reset Password</button>
              </form>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>
