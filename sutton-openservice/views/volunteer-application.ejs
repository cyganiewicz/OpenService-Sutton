<section class="section">
  <div class="wrap">
    <h1 class="section-title">Volunteer Application</h1>
    <p class="section-sub">Apply for an appointed seat on a Town board or commission.</p>

    <div class="form-shell">
      <% if (errors && errors.general) { %><div class="alert alert-error"><%= errors.general.msg %></div><% } %>
      <form method="POST" action="/volunteer-application" novalidate>
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="honeypot-field" aria-hidden="true">
          <label for="company_website">Leave this field blank</label>
          <input type="text" id="company_website" name="company_website" tabindex="-1" autocomplete="off">
        </div>

        <% fields.forEach(function (field) { %>
          <%- include('partials/dynamic-field', { field: field, value: values[field.name], error: errors[field.name] }) %>
        <% }); %>

        <% if (vacancies.length) { %>
        <div class="field">
          <label for="vacancyId">Specific vacancy (optional)</label>
          <select id="vacancyId" name="vacancyId">
            <option value="">— Not applying to a specific posted vacancy —</option>
            <% vacancies.forEach(function(v) { %>
              <option value="<%= v.id %>" <%= vacancyId === v.id ? 'selected' : '' %>><%= v.title %> (<%= v.departmentOrBoard %>)</option>
            <% }); %>
          </select>
        </div>
        <% } %>

        <p class="hint">By submitting, you consent to the Town of Sutton collecting and reviewing this information for the purpose of evaluating your volunteer application.</p>
        <button class="btn btn-primary" type="submit">Submit Volunteer Application</button>
      </form>
    </div>
  </div>
</section>
