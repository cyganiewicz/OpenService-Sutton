// Town of Sutton — OpenService
// Prisma schema targeting PostgreSQL (Railway)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum VacancyCategory {
  BOARD_COMMISSION
  TOWN_DEPARTMENT
}

enum VacancyStatus {
  OPEN
  CLOSED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  SEASONAL
  APPOINTED
  VOLUNTEER
}

enum ApplicationStatus {
  NEW
  UNDER_REVIEW
  INTERVIEWING
  CLOSED
}

enum AdminRole {
  ADMINISTRATOR
  STAFF
}

enum PayType {
  HOURLY
  SALARIED
  STIPEND
  UNPAID
  OTHER
}

enum FormType {
  VOLUNTEER
  EMPLOYMENT
}

enum FieldType {
  TEXT
  TEXTAREA
  EMAIL
  TEL
  DATE
  NUMBER
  SELECT
  RADIO
  CHECKBOX_GROUP
  CHECKBOX_SINGLE
  SECTION_HEADER
  PARAGRAPH
}

// One row per admin-configurable question on the Volunteer or Employment
// application form. `name` is the stable machine key used both as the form
// input's `name` attribute and as the key under which the answer is stored
// in VolunteerApplication.responses / EmploymentApplication.responses — so
// renaming `label` is always safe, but changing `name` after a field has
// live submissions orphans those old answers under the old key.
// Employment's repeating sections (work history, education, computer
// skills, references), resume upload, and signature/acknowledgement are
// NOT represented here — they don't fit a single-value field model (rows
// repeat, a file has bytes to store, the signature date is server-set) and
// stay as fixed columns on EmploymentApplication so the form still matches
// the Town's official paper form for those parts.
model FormField {
  id        String    @id @default(cuid())
  formType  FormType
  name      String
  label     String
  fieldType FieldType
  required  Boolean   @default(false)
  helpText  String?
  // Choice list for SELECT / RADIO / CHECKBOX_GROUP, e.g. ["Yes","No"].
  options   Json?
  order     Int
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([formType, name])
}

// Mirrors the table connect-pg-simple manages for Express sessions (see the
// `pgSession` setup in src/app.js — tableName: "user_sessions"). Prisma
// itself never reads or writes rows here; this model exists ONLY so that
// `prisma db push` recognizes the table as intentional and doesn't propose
// dropping it as "drift" every deploy (which is exactly what caused a
// crash-on-deploy: db push saw an unrecognized table with a live admin
// session in it and refused to proceed without --accept-data-loss). Column
// types are matched exactly to connect-pg-simple's own schema so this is a
// no-op diff, not an actual migration.
model Session {
  sid    String   @id @db.VarChar
  sess   Json     @db.Json
  expire DateTime @db.Timestamp(6)

  @@index([expire])
  @@map("user_sessions")
}

model AdminUser {
  id                 String    @id @default(cuid())
  email              String    @unique
  passwordHash       String
  name               String
  role               AdminRole @default(STAFF)
  active             Boolean   @default(true)
  // Forces a password change on next login — set true whenever an
  // ADMINISTRATOR creates an account or resets someone's password.
  mustChangePassword Boolean   @default(true)
  createdAt          DateTime  @default(now())
  lastLoginAt        DateTime?
}

model BoardCommission {
  id          String     @id @default(cuid())
  name        String     @unique
  description String?
  totalSeats  Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  seats       BoardSeat[]
  vacancies   JobVacancy[]
}

model BoardSeat {
  id                String          @id @default(cuid())
  boardCommission    BoardCommission @relation(fields: [boardCommissionId], references: [id], onDelete: Cascade)
  boardCommissionId String
  seatTitle         String          // e.g. "Chair", "Member", "Alternate"
  memberName        String?
  appointedDate     DateTime?
  termExpires       DateTime?
  vacant            Boolean         @default(false)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

model JobVacancy {
  id                String           @id @default(cuid())
  category          VacancyCategory
  title             String
  departmentOrBoard String
  boardCommission    BoardCommission? @relation(fields: [boardCommissionId], references: [id])
  boardCommissionId String?
  employmentType    EmploymentType
  description       String           // sanitized HTML from the admin rich-text editor
  qualifications     String?         // sanitized HTML from the admin rich-text editor
  payType            PayType?
  payMin             Float?
  payMax             Float?
  payNote            String?         // e.g. "commensurate with experience", "+ benefits"
  postedDate         DateTime        @default(now())
  closingDate        DateTime?
  status             VacancyStatus   @default(OPEN)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  volunteerApplications  VolunteerApplication[]
  employmentApplications EmploymentApplication[]
}

// Every user-facing question on the Volunteer form is a simple single-value
// answer, so the whole thing is driven by FormField (formType: VOLUNTEER)
// and stored here as one JSON object keyed by FormField.name.
model VolunteerApplication {
  id          String            @id @default(cuid())
  vacancy     JobVacancy?       @relation(fields: [vacancyId], references: [id])
  vacancyId   String?
  responses   Json
  status      ApplicationStatus @default(NEW)
  submittedAt DateTime          @default(now())
  submittedIp String?
}

model EmploymentApplication {
  id        String      @id @default(cuid())
  vacancy   JobVacancy? @relation(fields: [vacancyId], references: [id])
  vacancyId String?

  dateOfApplication DateTime @default(now())

  // Admin-configurable single-value questions (formType: EMPLOYMENT),
  // e.g. name, address, email/phone, eligibility yes/no questions, referral
  // source, military history, civic activities — one JSON object keyed by
  // FormField.name.
  responses Json

  // Fixed sections that mirror the Town's official paper form structure and
  // don't fit a single-value field model — kept out of the drag-and-drop
  // builder on purpose (see the FormField model comment).
  employmentHistory   Json
  volunteerWorkHistory String?
  education           Json
  specializedTraining  String?
  computerSkills       Json
  references           Json

  signatureTypedName String
  signatureDate      DateTime
  acknowledged       Boolean

  resumeFileName String?
  resumeFileType String?
  resumeFileData Bytes?

  status      ApplicationStatus @default(NEW)
  submittedAt DateTime          @default(now())
  submittedIp String?
}
